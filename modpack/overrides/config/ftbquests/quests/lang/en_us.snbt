	quest.57C9F7080F40503B.title: "正式开始你的工程师之旅"
	quest.580BD15704308603.quest_desc: ["同安山机壳，手持黄铜锭右键去皮原木"]
	quest.580BD15704308603.quest_subtitle: "给机壳换个材料"
	quest.5914F05FDA08DDF1.quest_desc: [
