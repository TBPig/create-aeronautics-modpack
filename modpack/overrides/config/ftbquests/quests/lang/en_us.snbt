{
	chapter.5611A7EEFC896A91.title: "[并非教程][主线-3]新手向机械动力"
	quest.05D5DE09C10EA9C1.quest_desc: [
		"蒸汽笛是一种声音方块。"
		""
		"蒸汽笛需要依附在 锅炉 上以使用，需要在锅炉下方放置热源，但不需要消耗蒸汽。当它接收红石信号时持续发出声音。"
		""
		"蒸汽笛的默认音调为 #F。在上方堆叠蒸汽笛 能够降低音调，每个降低一个半音，最多可堆叠12个。"
		""
		"使用扳手右击能够调整其宽度，细的蒸汽笛能够将音域提高八度，而粗的则降低八度。"
	]
	quest.05D5DE09C10EA9C1.quest_subtitle: "MC是音游"
	quest.05D5DE09C10EA9C1.title: "蒸汽机在轰鸣"
	quest.07DC3DE21D2A3FB5.quest_desc: [
		"查阅jei："
		""
		"1.石英+红石->玫瑰石英"
		"2.沙子+纸->砂纸"
		"3.玫瑰石英+砂纸(置于双手长按右键)->磨制玫瑰石英"
		"4.磨制玫瑰石英+铁板->晶体管"
	]
	quest.07DC3DE21D2A3FB5.quest_subtitle: "红石伟大，无需多言"
	quest.095341F447027B99.quest_desc: [
		"流水线装配，是使用各类机械与当前的半成品配方交互若干次以完成物品的制作。"
		""
		"精密构件则往往是你以此法生产的第一个物品。"
		""
		"你需要准备任务所要求机器以便开始第一次制作"
	]
	quest.095341F447027B99.quest_subtitle: "1769年，英国人乔赛亚·韦奇伍德开办埃特鲁利亚陶瓷工厂，首次实行流水线作业"
	quest.095341F447027B99.title: "流水线装配"
	quest.11A745B93068C191.quest_desc: [
		"查看jei合成 石磨"
		"将物品丢入其上方/或使用漏斗从任意方向输入"
		"用漏斗将产品取出/空手右键取出产品"
	]
	quest.11A745B93068C191.quest_subtitle: "石磨棍硌"
	quest.11A745B93068C191.title: "粉碎他"
	quest.135754F806BB3299.quest_desc: [
		"自己喂食烈焰人还是太麻烦了，你可以使用机械手或者动力臂进行自动化投喂。"
		""
		"使用机械手投喂时，需要将机械手隔一个方块对准烈焰人燃烧室。"
		""
		"使用动力臂投喂时，需要在放置动力臂前，拿着它右键绑定至少一个摆有燃料的工作盆置物台/传送带，和若干个烈焰人燃烧室。注意，你需要透过传送带等其它方式向工作盆/置物台提供燃料。"
	]
	quest.135754F806BB3299.quest_subtitle: "在电影《摩登时代》中有一个经典片段中，工厂老板为了提高工人工作效率，试图引进“自动喂食机”以节省吃饭时间来工作。"
	quest.1393D7BD6B546018.quest_desc: [
		"查看合成表合成转速控制器"
		"这下你不用通过许多的大小齿轮来调整转速了"
		"对其按[w]查看用法"
	]
	quest.16F79547701CB1AD.quest_desc: [
		"查看jei合成 动力合成器"
		"是一个自动档工作台"
		"可查看[w]查看用法"
	]
	quest.16F79547701CB1AD.quest_subtitle: "在1.21迎来了竞争对手"
	quest.18373797D07E3AC5.quest_desc: [
		"查看jei合成 动力搅拌器"
		"在它的侧面用旋转的齿轮提供动力"
		"在它的下方隔一格放置 工作盆"
		"向工作盆里Q键丢入材料/漏斗从任意方向输入"
		"空手右键可以取出其中的材料"
		"具体的合成表查阅jei"
		"Tps：用它合成安山合金比工作台中合成产量提高了100%"
	]
	quest.18373797D07E3AC5.quest_subtitle: "格楞格楞"
	quest.1D956F158D611F0F.quest_desc: [
		"查看jei合成 动力锯"
		"可以横放/竖放/倒放"
		"从背部接入应力"
		"工作时会对面前一格原木进行切割"
		"若此原木为大树连接土地的部分"
		"则将整棵树瞬间破坏"
		"当它竖放时"
		"可按Q键向他丢出原料加工原料"
		"具体的合成表查阅jei"
		"Tps："
		"1.原木->去皮原木->6*木板，血赚"
		"2. 切割面包制作的面包片是制作三明治的必需品"
	]
	quest.1D956F158D611F0F.quest_subtitle: "欢乐喜锯人"
	quest.1FBCFB2DB202F854.quest_desc: [
		"查看jei合成 动力钻头"
		"可以横放/竖放/倒放"
		"从背部接入应力"
		"工作时会对面前一格方块进行破坏"
		"Tps：黑曜石也能破坏"
		"Tps：用来做刷石机时不错的机器"
	]
	quest.1FBCFB2DB202F854.quest_subtitle: "电光毒龙钻"
	quest.20694D34548E76CB.quest_desc: [
		"用于在世界上建造对称图形，默认按住Shift+右键打开GUI界面"
		""
		"右键地面创建镜子，右键空气删除镜子。每个对称法杖可以创建一面镜子，多个对称法杖可以创建多于一面镜子。"
		""
		"有效范围是以镜子为中心的50格半径。"
		""
		"当玩家在有效范围内放置或摧毁方块会将玩家的操作反射到镜子另外一面。"
		""
		"&eeg:如果玩家放置了一个平面镜，再在镜子前面放一个木板1，那么镜子后面也会出现一个木板2，但是会额外消耗一个木板。如果木板1被破坏，那么对面的木板2也会消失，并在木板1的掉落位置再掉落一个。其他模式也有这个效果，但是作用位置和消耗数量会变化。不会影响镜子放置前已经出现的方块，也不会复制强力胶的胶。"
	]
	quest.21838A9B28A32675.quest_desc: [
		"14.电吹风（压力山大）"
		"查看jei合成 鼓风机"
		"可以横放/竖放/倒放"
		"从背部接入应力"
		"工作时根据接入应力的旋转方向吸/吹动面前的实体"
		"当风经过特定方块时会发生变化"
		""
		"发生变化的风会和某些掉落物产生奇妙的反应（查看jei）"
		"经过&6岩浆&r（批量熔炼）：处理所有熔炉的配方，除了烟熏炉的配方；点燃玩家/生物"
		""
		"经过&c火/篝火&r（批量烟熏）：处理烟熏炉的所有配方；点燃玩家/生物"
		""
		"经过&b灵魂火/灵魂篝火&r（批量缠魂）：处理机械动力特有配方；令玩家失明/生物"
		""
		"经过&9水/含水方块&r（批量洗涤）：处理机械动力特有配方；熄灭玩家/生物身上的火焰"
		"Tps：鼓风机获得的转速不影响处理速度，但影响吹出风的距离和推动物体的力"
		"             可通过多个鼓风机吹同一个物品来增加工作速度"
		"             批量熔炼会销毁不可被处理的物品"
	]
	quest.21838A9B28A32675.quest_subtitle: "小猪佩奇"
	quest.221F70ED534E912F.quest_desc: [
		"查看jei合成 空的烈焰人燃烧室"
		"拿着右键烈焰人或烈焰人刷怪笼即可装入"
		"这下烈焰人只能一辈子当你的奴隶了"
	]
	quest.221F70ED534E912F.quest_subtitle: "我的世界也要有自己的帕鲁"
	quest.24457C8610A96626.quest_desc: [
		"通过鼓风机将怪物吸过来"
		"通过移动结构中的动力钻头或左手模式机械手处死"
		"通过漏斗矿车/漏斗/机械动力物流收集掉落物"
		"要求：后续无需任何输入物可运行"
		"产量要求：火药+腐肉+骨头+线 16/min"
	]
	quest.24457C8610A96626.title: "【挑战】刷怪塔"
	quest.284F8C0690A925AC.quest_desc: [
		"  不同于大多数科技模组，机械动力的机壳不通过工作台获得，你需要将去皮原木放置在地面上，再使用安山合金右键获得安山机壳。"
		"  前期所有的机械均需要安山机壳"
	]
	quest.284F8C0690A925AC.quest_subtitle: "年轻人的第一款机壳"
	quest.284F8C0690A925AC.title: "第一款机壳"
	quest.2895EAE6769E399F.quest_desc: [
		"锅炉是原版机械动力产能的巅峰，接下来本任务将会教你如何搭建一个实用的锅炉。&7（你可以自己学习锅炉的组成方式，并用自己喜欢的其他方式进行摆放）"
		"&r"
		"1.准备材料，需要：流体储罐*36+烈焰人燃烧室*9+动力泵*1+蒸汽引擎*9"
		""
		"2.在第1层将烈焰人燃烧室3x3摆放"
		""
		"3.在第2~5层将流体储罐按3x3x4摆放"
		""
		"4.使动力泵从无限水中抽水，通入流体储罐中，并使得动力泵至少获得192的转速（你可以使用多个动力泵，并使它们的转速之和不小于192"
		""
		"5.在流体储罐边上任意位置贴放蒸汽引擎"
		""
		"6.至此，你做好了一个lv9锅炉，向烈焰人提供足够的燃料后，即可使用传动杆放置在蒸汽引擎前面隔一格，获得巨大的应力。（这样的一个锅炉能产生约144k应力，等同于288个大水车）"
		""
		"&eTips1：也许你需要树厂来提供足够的木板"
		"&eTips2：也许你需要机械手或动力臂来进行自动投喂"
	]
	quest.2895EAE6769E399F.quest_subtitle: "“机器嗡嗡响个不停、烟味刺鼻、灰烬和煤烟遮挡住视线—这是时代变迁的标志。科学和文化进步的诱惑是推动你的王国不断向前发展的动力。现在，你面临的挑战是维持地球和人类、和平与战争之间微妙的平衡。”"
	quest.2895EAE6769E399F.title: "蒸汽时代！"
	quest.29A817DF224BD246.quest_desc: [
		"使传送带承载着金板，依次经过拿着 齿轮，大齿轮，铁粒 的机械手（别忘了通上应力）并循环五遍，完成后，你将有80%的概率获得精密构件。"
		""
		"Tps：你可以另使用另外一条方向相反的传送带将物品从尾部运到头部，实现自动化装配。不同的物品有着不同的装配顺序和成功率，可使用jei查看。"
	]
	quest.29A817DF224BD246.quest_subtitle: "精密仪器"
	quest.29A817DF224BD246.title: "高精尖技术"
	quest.2B6BB29D52ADC77B.quest_desc: [
		"注液器：使用流体装填容器物品（如桶，玻璃瓶）；执行注液配方（如草方块，烈焰蛋糕的配方等）。"
		""
		"分液池：从载有流体的物品中提取流体。"
		""
		"软管滑轮：用于抽取或排放大面积流体。"
		""
		"流体储罐：存储液体，无法和桶直接交互。"
		""
		"移动式流体接口：对动态结构抽取/输入流体的元件，同“移动式存储接口”。"
	]
	quest.2B6BB29D52ADC77B.title: "处理流体"
	quest.2CAFE744BECF8894.quest_desc: [
		"如果你不嫌麻烦，可以使用手摇曲柄产生“应力”。"
		""
		"Tps：持续右键手摇曲柄的过程中会消耗饥饿值"
		"（作者刚学机械动力的时候就喜欢用这玩意）"
	]
	quest.2CAFE744BECF8894.quest_subtitle: "一摇一个不吱声"
	quest.2DE2318DA050437B.quest_desc: [
		"查阅jei可知用搅拌机在工作盆内搅拌加热的铜和锌可以合成黄铜"
		"为了加热，我们需要将烈焰人燃烧室放在工作盆下方"
		"手持可燃物（包括烈焰棒）可喂食烈焰人让其工作发热"
	]
	quest.2DE2318DA050437B.quest_subtitle: "工业革命"
	quest.2DE2318DA050437B.title: "黄铜时代"
	quest.3209766DFD5E3282.quest_desc: [
		"可以搭建钟，旋转第一个连接的结构作为时针 第二个作为分针。链接方式为在转盘面一次放置两个不相连的结构。——MC百科"
		""
		"对其长按[w]查看详细内容。"
	]
	quest.3209766DFD5E3282.quest_subtitle: "其实是钟"
	quest.34709BA239C468ED.quest_desc: [
		"查看合成表合成动力臂"
		""
		"动力臂具有从多个地方向多个地方转移物品的能力"
		""
		"对其长按[w]查看详细用法"
		""
		"&eTps:当你用动力臂往唱片机塞入唱片时会发现很有意思的事情"
	]
	quest.34709BA239C468ED.quest_subtitle: "为什么不叫《物流系统v3.0》？"
	quest.38FE3E36F068A300.quest_desc: [
		"查看jei，通过自动合成器合成粉碎轮"
		"比磨石更大，更强，更快"
		"查看jei可知它能干的事情"
		"奖励会给你一些可研磨物"
	]
	quest.38FE3E36F068A300.title: "更大，更强的粉碎！"
	quest.3CE296642EC070A4.quest_desc: [
		"位于移动结构上的动力结构元件会自行工作，无需应力驱动"
		""
		"箱子/木桶：储存物品，动力元件破坏方块产生的掉落物会被自动存入其中"
		""
		"动力锯：砍倒接触到的树，对接触到的实体造成伤害"
		""
		"动力钻头：破坏接触到的方块，对接触到的实体造成伤害"
		""
		"动力犁：破坏附着性方块eg：火把、拉杆，将下方的土变为耕地"
		""
		"动力收割机：收割并种植作物"
		""
		"机械手：模拟玩家使用方块"
		""
		"移动式存储接口：当移动结构中的接口 和 作为方块的接口 隔一个/两个方块相对时，它们会开始连接。此时对方块形式的接口进行输入输出视为对移动结构进行输入输出"
		""
		"对其长按[w]查看详细内容。"
	]
	quest.470DCD80315AAA2F.quest_desc: [
		"所有运动锚点默认只让其有粘液贴图粘连的一个方块移动"
		"你需要使用强力胶将这个方块和其他方块框为一个整体、或者通过底盘(较为复杂，可通过[w]查看用法)"
		""
		"风车轴承：除了放置风帆之外，也可以驱动其他方块旋转，但仍需要至少8个风帆以启动"
		""
		"动力轴承：与风车轴承一致，但需要在背部连接动力以驱动"
		""
		"矿车装配站：放置于铁轨上，当内部放有矿车时连接红石信号可形成跟随矿车移动的结构，不连接红石信号可卸下矿车上的移动结构，在侧边可以调整其模式"
		"&e可用扳手shift+右击装有移动结构的矿车，使其变为物品形式"
		"&4Tps：将大结构矿车转入背包是危险的，在你下次登陆时很可能因为nbt过大登陆失败"
		""
		"&r动力活塞：在背部放置活塞杆（放置多少根就能将面前物体推动多少格）后在一侧连接传动杆以驱动，通过传动杆旋转的方向觉得活塞臂伸出还是收回"
		""
		"运动锚点还有很多，可通过[w]自行学习探索"
	]
	quest.48C13EB41B1836F1.quest_desc: [
		"工程师护目镜可以被戴在头部，当同时安装了饰品栏mod时也可以作为饰品携带。"
		""
		"携带护目镜时，你可以看到机器产生或消耗了多少应力。"
		""
		"对其长按[w]查看更多信息"
	]
	quest.48C13EB41B1836F1.quest_subtitle: "你是说——你能用肉眼看出机器的应力消耗？"
	quest.48C13EB41B1836F1.title: "应力可视化"
	quest.4D99BDBB2CE4C3C3.quest_desc: ["将小麦碾磨成粉，水洗成面团，再和黄绿色染料混合，你就得到了粘液球！"]
	quest.4D99BDBB2CE4C3C3.quest_subtitle: "新的合成方式！"
	quest.4D99BDBB2CE4C3C3.title: "粘液球"
	quest.4E1225F4D4D383E6.quest_desc: ["通过使用 动力锚点连接动力等原件，实现树木的自动砍伐。"]
	quest.5723777466E08E16.quest_desc: [
		"在使用机械前，你需要有能量使它们能够动起来，清洁而无尽的风能不失为一种优秀的选择"
		""
		"查看jei合成得到&6风车轴承&r"
		""
		"将风车轴承放在任意位置后（可以横放或者竖放），在它的吸盘前放下连接在一起的风帆（至少8个）。右击风车轴承启动它后，你可以在尾部看到有根杆在旋转说明它开始输出“应力”了。你可以在此处通过传动元件（后文会介绍）连接获取。"
	]
	quest.5723777466E08E16.quest_subtitle: "哈里路大旋风！"
	quest.5723777466E08E16.title: "感受风能"
