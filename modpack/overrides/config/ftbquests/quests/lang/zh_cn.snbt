	quest.3F361BD0D56B7A22.title: "飞艇"
	quest.40E3B933C1ADD68B.quest_desc: [
		"通过造石厂生产圆石"
		""
		"通过磨石/粉碎轮将圆石->沙砾"
		""
		"通过磨石/粉碎轮将沙砾->沙子"
		""
		"通过鼓风机缠魂沙子->灵魂沙"
