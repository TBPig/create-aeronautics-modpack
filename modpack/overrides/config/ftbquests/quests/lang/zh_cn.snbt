	quest.21838A9B28A32675.quest_desc: [
		"可以横放/竖放/倒放"
		""
		"从背部接入应力"
		""
		"工作时产生风，根据接入应力的&d旋转方向&r吸/吹动面前的实体"
		""
		"当风经过特定方块时会发生变化"
		""
		"发生变化的风会和某些掉落物产生奇妙的反应（查看jei）"
		""
		"经过&a岩浆&r（批量熔炼）：处理所有熔炉的配方，除了烟熏炉的配方；点燃生物"
		"经过&a火/篝火&r（批量烟熏）：处理烟熏炉的所有配方；点燃生物"
		"经过&a灵魂火/灵魂篝火&r（批量缠魂）：执行特殊配方；令生物失明"
		"经过&a水/含水方块&r（批量洗涤）：执行特殊配方；熄灭生物身上的火焰"
		"经过&a分散网&r：使得风的影响范围从一条线改为一片区域"
		""
		"Tps：鼓风机获得的转速不影响处理速度，但影响吹出风的距离和推动物体的力"
		"Tps：可通过多个鼓风机吹同一个物品来增加工作速度"
		"Tps：批量熔炼会销毁不可被熔炉处理的物品"
	]
	quest.221F70ED534E912F.quest_desc: [
