		"选定范围后，可以用&ectrl+鼠标滚轮&r调整范围"
		""
		"为了便于区分，建议将&a蜂蜜胶&r用于&d模拟结构&r；将&a强力胶&r用于&d移动结构&r"
	]
	quest.56535CE4BF11612B.quest_desc: [
		"提供各种便捷功能"
		""
		"&eX+C&r 进行配置"
	]
	quest.56A24FEBDC3351F4.title: "研磨"
	quest.5723777466E08E16.quest_desc: [
		"{image:quests:textures/pic/windmill.png width:120 height:100 align:center}"
		""
		"&a风车轴承&r需要8个&d风帆方块&r才能启动，可以使用羊毛，风帆，风帆框架。"
		""
		"搭建完成后右键&a风车轴承&r即可启动"
		""
		"每有8个风帆方块，提供 &e1 RPM | 512 su&r"
		""
		"一个&a风车轴承&r最多提供 &e16 RPM | 8192 su&r"
	]
	quest.580AEB4DF1094CC9.quest_desc: [
		"推荐观看B站系列教程视频："
		""
		"专题精讲 &bhttps://www.bilibili.com/video/BV1CGdqYREfF"
		""
		"方块介绍 &bhttps://www.bilibili.com/video/BV1FBXQYWEZU"
	]
	quest.580AEB4DF1094CC9.title: "智能物流"
	quest.580BD15704308603.quest_desc: ["同安山机壳，手持黄铜锭右键去皮原木"]
	quest.585FF45F6EAB3E32.title: "破坏"
	quest.58D087734AD52547.quest_desc: ["破坏接触到的方块，对接触到的实体造成伤害"]
	quest.5914F05FDA08DDF1.quest_desc: [
		"1.传送带"
		""
		"2.安山漏斗/黄铜漏斗"
		""
		"3.溜槽/智能溜槽"
		""
		"构成了机械动力主要的物流系统，长按&e[W]&r可查看用法"
		""
		"Tps：传送带即可&d运输物品&r，也能&d运输实体&r，按住shift可防止自己被运输"
		"Tps：可以通过&d红石信号&r关闭漏斗与智能溜槽"
		"Tps：黄铜漏斗和智能溜槽才可以设置&d过滤器&r，但其需要黄铜（之后会提）"
	]
	quest.5914F05FDA08DDF1.title: "物流系统"
	quest.5AC5FBA95DC30DE4.quest_desc: [
		"喂给烈焰人，使其超级燃烧，执行更多配方"
		""
		"对锅炉而言，此时的烈焰人将产生两倍的热量"
	]
	quest.5BCA0FAD6AB9AE59.quest_desc: ["其输出的红石信号将缓慢变化，最终等同于其背部受到的信号"]
	quest.5CE8651FFBE1D750.quest_desc: [
		"黄铜漏斗：输出量相比安山漏斗更大，且可以设置过滤"
		""
		"智能溜槽：输出量相比溜槽更大，且可以设置过滤"
		""
		"智能侦测器"
		""
		"存量检测器"
		""
		"长按[W]可查看用法"
	]
	quest.5CE8651FFBE1D750.title: "高级物流系统"
	quest.5EEC611BE589C5D6.title: "农场"
	quest.5F1430224B8E87DB.title: "直升飞机"
	quest.5F9B6C0597CC92D8.quest_desc: [
		"通过传动杆与齿轮/大齿轮可以传递应力"
		""
		"对着物品长按&e[W]&r查看具体连接方式"
		""
		"在服务器游玩时，请尽量少使用齿轮传输，较卡"
	]
	quest.5F9B6C0597CC92D8.title: "应力传输"
	quest.5FA2B228458C23AE.quest_desc: [
		"将它有接口的一侧通过传动杆连接应力源"
		""
		"将物品扔到它的下方一格处，它会开始工作，将铁、铜等金属压成板"
		""
		"Tps记得及时把东西拿走"
	]
	quest.601DDD1CC1F5F689.quest_desc: ["在背部放置活塞杆（放置多少根就能将面前物体推动多少格），在一侧接入应力以驱动，通过旋转的方向决定活塞臂伸出还是收回"]
	quest.609EB1D82C25F15D.quest_desc: [
		"智能侦测器、存量检测器、辉光管、接触式红石信号发生器、模拟拉杆、无限红石信号终端、脉冲延长器、脉冲中继器、锁存器、转换锁存器、玫瑰石英灯"
		""
		"为原版红石信号做了加强"
		""
		"可查看[W]查看用法"
		""
		"（太多了，懒得写）"
		"（这些东西是真的好用）"
	]
	quest.609EB1D82C25F15D.title: "智能红石元件"
	quest.6137CDBE148CC666.quest_desc: [
		"机械动力中，&d移动结构&r是最重要的一部分"
		""
		"在制作&d移动结构&r之前"
		""
		"我们需要用强力胶将方块们组合起来"
		""
		"右键两个位于长方体同一条对角线的方块，将这个长方体内部的方块连接起来"
		""
		"Tps：原版的活塞不认&d移动结构&r"
		"Tps：可以通过铁砧为&a强力胶&r打上耐久III和经验修补附魔"
		"[ \"Tps：\", { \"text\": \"粘液球(点我)\", \"color\": \"blue\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"4D99BDBB2CE4C3C3\" } }, \"可以制作，不用去满世界找史莱姆\" ]"
	]
	quest.61D17F24C202CB19.quest_desc: ["更好的挖掘工具"]
	quest.62AF180B02B9AF1E.quest_desc: [
		"如果背部输入信号，其输出的信号强度缓慢增加"
		""
		"如果侧方输入信号，其输出的信号强度缓慢减少"
	]
	quest.6310FEC95461CAFE.quest_desc: [
		"我有两块安山岩"
		"我有两个铁粒"
		"Boom！"
		"安山合金"
		"安山合金是一切的起点，游玩机械动力前请确保你获得了足够的安山合金"
	]
	quest.6583CCE9C31E5A57.quest_desc: ["箱子、木桶和保险库仍然可以储存物品和打开，其他动力元件破坏方块产生的掉落物会被自动存入其中"]
	quest.674F36D8C1A90D62.quest_desc: ["软连接，力够大就能拆开两块被吸引的磁铁"]
	quest.687B0F2D504691BE.title: "冶炼"
	quest.68BD182E4A13D811.title: "喷气飞机"
	quest.68EC8461DD055304.title: "水洗"
	quest.6917737CAFB3057D.quest_desc: [
		"模拟结构具有&d重心&r和&d质量&r"
		""
		"质量为结构中所有方块之和，大部分方块的质量默认为&e 1 kg&r，如果不是，会在tooltips中特别说明"
		""
		"模拟结构会受到一个始终向下的重力，重力的大小和质量相关"
		""
		"本世界中，g =&e 11 N/kg&r"
		""
		"如果看不懂，可以询问你的科学老师"
	]
	quest.6B7200323CE89A5A.quest_desc: [
		"无魔改，尽情游玩航空学吧"
		""
		"本整合包主要为《机械动力：航空学》制作"
		""
		"推荐长按&e[W]&r键，观看模组制作者官方的演示教程，比任务线更加生动活泼"
	]
	quest.6C842943E82DB163.quest_desc: ["鼓风机的风经过&a灵魂火/灵魂篝火&r可以批量缠魂，将沙子(物品形态)变为灵魂沙"]
	quest.6D9916C069F8C992.quest_desc: [
		"模组名 hotbaaaar"
		""
		"可自行关闭，或通过config调整长度"
	]
	quest.6DC3E3ECA0A85CBF.quest_desc: ["用力太大会把弹簧拉断"]
	quest.6EDE8E24B12BCAE1.quest_desc: ["用&a鼓风机&r吹风，经过水，对物品形态的沙砾进行水洗，产生铁粒"]
	quest.708EC2B23CD7C05B.title: "缠魂"
	quest.719AE5E2C4034F5E.quest_desc: [
		""
		"{image:quests:textures/pic/water_wheel.png width:100 height:100 align:center}"
		""
		"水车需要流动水才能工作"
		""
		"&a水车&r提供 &e8 RPM | 256 su&r"
		""
		"&a大水车&r提供 &e4 RPM | 512 su&r"
	]
	quest.7316D6B0A34F9FE7.quest_desc: [
		"查阅合成表：使用电子管、黄铜机壳、黄铜手部零件合成&a机械手&r"
		""
		"默认对面隔一个方块位置的方块或面前的实体&d模仿玩家&r按下左键/右键"
		""
		"放下时，默认为右键，扳手右键手部可&d切换模式&r"
		""
		"其他物品右键手部即可交给它"
		""
		"其侧部可以放置&a过滤器&r或物品，过滤其可使用的物品"
		""
		"当其朝下隔一格方块对着&a传送带/置物台&r时使用右键模式，可用手中的物品处理传送带上的物品"
		""
		"Eg1:手持安山合金，令 去皮原木->安山机壳"
		"Eg2:手持砂纸，令 玫瑰石英->磨制玫瑰石英"
		""
		"当其处于&d动态结构&r中时，会自动选取同一个动态结构中的容器中的物品尝试使用（支持过滤）"
		""
		"按[W]可查看用法"
	]
	quest.760E6D43C4E3D14E.quest_desc: [
		"如果你开始跑步，在站着的别人眼里，你越来越远。但在你眼里，站着的人也在移动，这就是&d相对运动&r"
		""
		"如果模拟结构&d开始向前运动&r，从模拟结构的角度看，那么周围的空气就在&d向后运动&r。此时，&a螺旋桨&r因为其原理——空气的速度越快其提供的力越小——无法无限加速结构。"
	]
	quest.762731FF779D89ED.quest_desc: [
		"如果你从未接触过机械动力，建议先完成&e机械动力章节&r的任务再来此处"
		""
		"将其放置在方块上时，拉下，你可以发现方块可以自由的旋转、滚动"
		""
		"这是因为它创造了&d模拟结构&r"
		""
		"&d模拟结构&r不同于&d动态结构&r："
		""
		"1. 绝大多数方块仍然可以正常运行"
		""
		"2. 模拟结构收到重力影响"
		""
		"3. 模拟结构中可以内嵌一个动态结构"
	]
	quest.762731FF779D89ED.title: "模拟结构"
	quest.763A2BC3200EB4E1.quest_desc: ["通过&a动力钻头&r，原版刷石机，漏斗制作一个自动的小刷石机"]
	quest.76EE44B9A618AE4C.quest_desc: [
		"默认在屏幕左上角显示信息"
		""
		"&eH&r 关闭 "
		""
		"&eH+C&r 调整"
	]
	quest.77AF0FD1A5FC69AC.quest_desc: [
		"在机械动力中，三废岩之一的安山岩获得了无与伦比的地位"
		"他是一切机械的起点，工业的基石"
		"那么现在，去地下弄点原材料吧"
	]
	quest.7C7A87255557B601.quest_desc: [
		"机械动力提供了各种各样的加工方块&m&7，而不仅是各种熔炉&r。"
		""
		"而所有加工方块都需要&d应力&r&7（单位su）&r才能工作"
		""
		"所有加工方块的速度都和&d转速&r&7（单位RPM）&r相关，且转速越高，消耗的应力越多"
	]
	quest.7C7A87255557B601.title: "应力系统"
