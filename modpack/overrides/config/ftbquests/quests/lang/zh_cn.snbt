	quest.0DB72E42E1E1BACD.quest_desc: ["蓝色和红色代表两极，同极相斥、异极相吸，距离越近，磁力越强"]
	quest.0DB72E42E1E1BACD.title: "磁力"
	quest.11A745B93068C191.quest_desc: [
