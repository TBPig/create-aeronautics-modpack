	quest.24457C8610A96626.title: "刷怪塔"
	quest.25537E50976C8ECE.quest_desc: [
		"&d应力源&r在满足一定条件的情况下会持续提供应力"
		""
		"由于应力无法储存，若有消耗应力的方块，请确保&d应力源&r一直工作"
		""
		"同个系统中如果有多个应力源，&d应力&r可以叠加，&d转速&r取最大值"
	]
	quest.284F8C0690A925AC.quest_desc: ["将&a去皮原木&r放置在地面上，再使用&a安山合金&r右键，获得安山机壳"]
